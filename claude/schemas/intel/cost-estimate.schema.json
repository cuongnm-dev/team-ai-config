{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://etc.local/schemas/intel/cost-estimate.schema.json",
  "title": "Cost Estimate",
  "description": "Two-level cost estimate: TKCS aggregate (6 standard line items) + TKCT detailed (Function Point per TT 04/2020). Tier 3 doc-only — resume-feature SKIPS entirely. Producer: from-doc + manual interview. Consumed by tdoc-tkcs-writer §6 (aggregate) + tdoc-tkct-writer §10 (detailed FP). Hard-stop in from-doc Phase 8 if summary[] missing 6 standard line items. Justified by: TKCS §6 Đ13 (dự toán sơ bộ), TKCT §10 Đ14 + TT 04/2020 (chi tiết FP).",
  "type": "object",
  "required": ["schema_version", "basis", "summary"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },

    "basis": {
      "type": "object",
      "required": ["method"],
      "description": "TKCS §6.1 + TKCT §10.1 source.",
      "properties": {
        "method": {
          "type": "string",
          "enum": ["tt04-2020", "reference-projects", "vendor-quote", "expert-judgment", "mixed"]
        },
        "reference_projects": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Comparable projects used for benchmarking."
        },
        "calculation_date": { "type": ["string", "null"], "format": "date" },
        "currency_assumption": { "type": ["string", "null"], "default": "VND" },
        "inflation_assumption_pct": { "type": ["number", "null"], "minimum": 0 },
        "vat_included": { "type": "boolean", "default": false },
        "notes": { "type": ["string", "null"] }
      }
    },

    "summary": {
      "type": "array",
      "minItems": 6,
      "maxItems": 8,
      "description": "TKCS §6.2 aggregate table — 6 standard line items (PM, HW, deploy, training, consulting, contingency). Hard-stop in from-doc if any of 6 mandatory items missing.",
      "items": {
        "type": "object",
        "required": ["item_code", "item_name", "amount_vnd"],
        "properties": {
          "item_code": {
            "type": "string",
            "enum": ["I", "II", "III", "IV", "V", "VI", "VII", "VIII"],
            "description": "Roman numeral. I=phần mềm, II=phần cứng, III=triển khai, IV=đào tạo, V=tư vấn+QLDA, VI=dự phòng. VII/VIII for additional."
          },
          "item_name": { "type": "string", "description": "Vietnamese category name." },
          "amount_vnd": { "type": "integer", "minimum": 0 },
          "ratio_pct": { "type": ["number", "null"], "minimum": 0, "maximum": 100, "description": "Ratio of total. Auto-computed but stored for verification." },
          "expected_range_pct": { "type": ["string", "null"], "description": "Expected ratio range per TT 04/2020. Example: '~50-60%' for software." },
          "notes": { "type": ["string", "null"] }
        }
      }
    },

    "total_summary_vnd": { "type": ["integer", "null"], "minimum": 0, "description": "Sum of summary[].amount_vnd. Verified at validate time." },

    "detailed": {
      "type": ["object", "null"],
      "description": "TKCT §10 detailed cost. Optional in TKCS context, mandatory in TKCT.",
      "properties": {
        "software_cost": {
          "type": "object",
          "description": "TKCT §10.2. Function Point method per TT 04/2020.",
          "properties": {
            "function_points": {
              "type": "array",
              "description": "FP catalog — feature × FP_count × FP_unit_cost.",
              "items": {
                "type": "object",
                "required": ["feature_or_module", "fp_count"],
                "properties": {
                  "feature_or_module": { "type": "string", "description": "Feature name or feature_id." },
                  "fp_count": { "type": "number", "minimum": 0 },
                  "complexity_factor": { "type": ["number", "null"], "minimum": 0, "description": "TT 04/2020 complexity multiplier." },
                  "calculated_amount_vnd": { "type": ["integer", "null"], "minimum": 0 }
                }
              }
            },
            "total_fp_count": { "type": ["number", "null"], "minimum": 0 },
            "fp_unit_cost_vnd": { "type": ["integer", "null"], "minimum": 0 },
            "total_software_vnd": { "type": ["integer", "null"], "minimum": 0 }
          }
        },
        "hardware_cost": {
          "type": "object",
          "description": "TKCT §10.3. Cross-ref infrastructure.hardware[].",
          "properties": {
            "line_items": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["item_name", "quantity", "unit_price_vnd"],
                "properties": {
                  "item_name": { "type": "string" },
                  "spec": { "type": ["string", "null"] },
                  "quantity": { "type": "integer", "minimum": 1 },
                  "unit_price_vnd": { "type": "integer", "minimum": 0 },
                  "total_vnd": { "type": "integer", "minimum": 0 },
                  "infrastructure_ref": { "type": ["string", "null"], "description": "infrastructure.hardware[] index or reference." }
                }
              }
            },
            "total_hardware_vnd": { "type": ["integer", "null"], "minimum": 0 }
          }
        },
        "deployment_training_cost": {
          "type": "object",
          "description": "TKCT §10.4.",
          "properties": {
            "deployment_vnd": { "type": ["integer", "null"], "minimum": 0 },
            "training_vnd": { "type": ["integer", "null"], "minimum": 0 },
            "data_migration_vnd": { "type": ["integer", "null"], "minimum": 0 },
            "uat_support_vnd": { "type": ["integer", "null"], "minimum": 0 }
          }
        },
        "services_cost": {
          "type": "object",
          "description": "Consulting, project management, supervision.",
          "properties": {
            "consulting_vnd": { "type": ["integer", "null"], "minimum": 0 },
            "pmo_vnd": { "type": ["integer", "null"], "minimum": 0 },
            "supervision_vnd": { "type": ["integer", "null"], "minimum": 0 },
            "third_party_audit_vnd": { "type": ["integer", "null"], "minimum": 0 }
          }
        },
        "contingency_vnd": { "type": ["integer", "null"], "minimum": 0, "description": "Reserve. ≤ 10% of total per TKCS guidance." }
      }
    },

    "total_detailed_vnd": { "type": ["integer", "null"], "minimum": 0, "description": "Sum of detailed.* totals. Should match summary total ±5%." },

    "funding": {
      "type": ["object", "null"],
      "description": "TKCS §6.3 source.",
      "properties": {
        "primary_source": { "enum": ["state-budget", "local-budget", "ppp", "loan", "grant", "mixed", null] },
        "schedule": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["year", "amount_vnd"],
            "properties": {
              "year": { "type": "integer" },
              "amount_vnd": { "type": "integer", "minimum": 0 },
              "source": { "type": ["string", "null"] },
              "notes": { "type": ["string", "null"] }
            }
          }
        }
      }
    },

    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "message"],
        "properties": {
          "severity": { "enum": ["high", "medium", "low"] },
          "category": {
            "type": "string",
            "enum": [
              "missing-mandatory-line-item",
              "ratio-out-of-range",
              "summary-detail-mismatch",
              "contingency-too-high",
              "missing-fp-detail",
              "missing-funding",
              "currency-not-vnd",
              "other"
            ]
          },
          "message": { "type": "string" }
        }
      }
    }
  }
}
