{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://etc.local/schemas/intel/permission-matrix.schema.json",
  "title": "Permission Matrix",
  "description": "Role × Resource × Action assignments with ABAC-ready conditions. Cross-references actor-registry.roles[].slug and feature-catalog/sitemap resource ids. Pattern follows Casbin/AWS IAM/Spring Security conventions.",
  "type": "object",
  "required": ["schema_version", "model", "resources", "permissions"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "model": {
      "type": "string",
      "enum": ["rbac", "abac", "acl", "hybrid"],
      "description": "Must align with actor-registry.rbac_mode (excluding 'implicit' — implicit means no matrix)."
    },
    "resources": {
      "type": "array",
      "items": { "$ref": "#/definitions/resource" }
    },
    "permissions": {
      "type": "array",
      "items": { "$ref": "#/definitions/permission" }
    },
    "denials": {
      "type": "array",
      "description": "Explicit deny rules. Override allow per least-privilege principle.",
      "items": { "$ref": "#/definitions/permission" }
    },
    "uncovered_resources": {
      "type": "array",
      "description": "Resources mentioned in feature-catalog/sitemap but missing from permissions[]. Audit gap.",
      "items": {
        "type": "object",
        "required": ["id", "reason"],
        "properties": {
          "id": { "type": "string" },
          "reason": {
            "type": "string",
            "enum": [
              "no_evidence_in_doc_or_code",
              "ambiguous_role_assignment",
              "deferred_to_business",
              "external_system_managed"
            ]
          },
          "note": { "type": "string" }
        }
      }
    }
  },
  "definitions": {
    "resource": {
      "type": "object",
      "required": ["id", "type", "actions"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^(feature|route|entity|api|menu)\\.[a-z0-9._-]+$",
          "description": "Namespaced resource id. Examples: 'feature.approval-request', 'route./api/users', 'entity.User', 'menu.reports'."
        },
        "type": {
          "type": "string",
          "enum": ["feature", "route", "entity", "api", "menu"]
        },
        "ref": {
          "type": "string",
          "description": "Cross-ref to feature-catalog feature_id (e.g. 'F-012') or sitemap node id."
        },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "description": "Verb list. Common: create/read/update/delete/list/export/approve/reject/submit."
        },
        "description": { "type": "string" }
      }
    },
    "permission": {
      "type": "object",
      "required": ["role", "resource", "actions"],
      "properties": {
        "role": {
          "type": "string",
          "description": "Must match actor-registry.roles[].slug OR be the wildcard '*'."
        },
        "resource": {
          "type": "string",
          "description": "Must match resources[].id OR end with '.*' for prefix match."
        },
        "actions": {
          "oneOf": [
            { "type": "array", "items": { "type": "string" }, "minItems": 1 },
            { "type": "string", "const": "*" }
          ]
        },
        "effect": {
          "type": "string",
          "enum": ["allow", "deny"],
          "default": "allow"
        },
        "conditions": {
          "type": "array",
          "description": "ABAC predicates. Evaluated at request time when conditions are present.",
          "items": {
            "type": "object",
            "required": ["field", "op", "value"],
            "properties": {
              "field": { "type": "string", "description": "JSONPath into request context, e.g. 'request.amount'." },
              "op": {
                "type": "string",
                "enum": ["eq", "ne", "lt", "lte", "gt", "gte", "in", "not_in", "contains", "starts_with", "regex"]
              },
              "value": {}
            }
          }
        },
        "evidence": {
          "type": "array",
          "items": { "$ref": "actor-registry.schema.json#/definitions/evidence" }
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low", "manual"]
        }
      }
    }
  }
}
