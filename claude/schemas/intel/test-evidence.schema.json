{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://etc.vn/schemas/intel/test-evidence.schema.json",
  "title": "Test Evidence (per feature)",
  "description": "Captured by resume-feature QA stage. Contains Playwright test definitions, execution results, and screenshot map. Consumed by generate-docs Stage 3a (capture) + Stage 4f (xlsx) — generate-docs does NOT re-run Playwright when fresh evidence exists. Layout: one file per feature at docs/intel/test-evidence/{feature-id}.json.",
  "type": "object",
  "required": ["schema_version", "feature_id", "captured_at", "test_cases"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "1.0" },
    "feature_id": {
      "type": "string",
      "pattern": "^F-[0-9]{3,}$",
      "description": "FK → feature-catalog.json features[].id"
    },
    "captured_at": { "type": "string", "format": "date-time" },
    "captured_by": {
      "type": "string",
      "description": "Producer: 'resume-feature/qa', 'generate-docs/s3a' (fallback), 'manual'."
    },
    "playwright_config": {
      "type": ["object", "null"],
      "properties": {
        "base_url": { "type": "string" },
        "viewport": {
          "type": "object",
          "properties": {
            "width": { "type": "integer" },
            "height": { "type": "integer" }
          }
        },
        "browser": { "type": "string", "enum": ["chromium", "firefox", "webkit"] },
        "auth_state_files": {
          "type": "object",
          "description": "role_slug → storage state file path. Cross-ref test-accounts.json.",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "test_cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "role_slug", "steps", "expected_result"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^TC-F-[0-9]{3,}-[0-9]{2,}$",
            "description": "Test case id format: TC-{feature-id}-NN, e.g. TC-F-001-01"
          },
          "title": { "type": "string", "minLength": 10 },
          "role_slug": {
            "type": "string",
            "description": "FK → actor-registry.roles[].slug. Determines which test account/storage_state to use."
          },
          "priority": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          },
          "type": {
            "type": "string",
            "enum": ["functional", "negative", "boundary", "integration", "security", "ux"]
          },
          "preconditions": { "type": "array", "items": { "type": "string" } },
          "steps": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["order", "action"],
              "properties": {
                "order": { "type": "integer", "minimum": 1 },
                "action": { "type": "string", "minLength": 5, "description": "VN imperative: 'Nhấn nút Tạo mới', 'Nhập số tờ khai...'." },
                "expected": { "type": "string", "description": "Expected per-step result (optional, only when verifying mid-flow)." },
                "screenshot_id": {
                  "type": ["string", "null"],
                  "description": "FK → screenshots[].id. Captured at this step."
                },
                "playwright_locator": { "type": ["string", "null"], "description": "data-testid or role-based locator used by Playwright." }
              }
            }
          },
          "expected_result": { "type": "string", "minLength": 10, "description": "End-state assertion, the 'PASS criterion'." },
          "execution": {
            "type": ["object", "null"],
            "description": "Last execution result. Null if test defined but not yet run.",
            "properties": {
              "status": { "type": "string", "enum": ["passed", "failed", "skipped", "flaky"] },
              "duration_ms": { "type": "integer" },
              "executed_at": { "type": "string", "format": "date-time" },
              "playwright_report": { "type": ["string", "null"], "description": "Path to playwright HTML/JSON report." },
              "failure_reason": { "type": ["string", "null"] }
            }
          },
          "linked_acceptance_criteria_idx": {
            "type": "array",
            "items": { "type": "integer" },
            "description": "Indices into feature-catalog.features[].acceptance_criteria[] this TC validates. Coverage tracking."
          }
        }
      }
    },
    "screenshots": {
      "type": "array",
      "description": "Captured during test execution. Consumed by generate-docs HDSD writer.",
      "items": {
        "type": "object",
        "required": ["id", "path", "state"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^F-[0-9]{3,}-step-[0-9]{2,}-[a-z_]+$",
            "description": "Canonical naming: {feature-id}-step-NN-{state}. State vocab: initial|filled|success|error|loading|modal|list|detail|placeholder."
          },
          "path": { "type": "string", "description": "Relative path under repo root, e.g. docs/intel/screenshots/F-001-step-01-initial.png" },
          "state": {
            "type": "string",
            "enum": ["initial", "filled", "success", "error", "loading", "modal", "list", "detail", "placeholder"]
          },
          "viewport": { "type": "string", "enum": ["desktop", "mobile", "tablet"] },
          "role_slug": { "type": "string" },
          "test_case_id": { "type": ["string", "null"] },
          "step_order": { "type": ["integer", "null"] },
          "annotation": { "type": ["string", "null"], "description": "Optional VN caption for HDSD." }
        }
      }
    },
    "coverage": {
      "type": ["object", "null"],
      "properties": {
        "ac_covered": { "type": "integer", "description": "Count of acceptance criteria covered by ≥1 test case." },
        "ac_total": { "type": "integer" },
        "ac_coverage_pct": { "type": "number" },
        "code_coverage_pct": { "type": ["number", "null"] }
      }
    },
    "freshness": {
      "type": "object",
      "description": "Used by generate-docs to decide reuse vs re-run.",
      "properties": {
        "feature_catalog_hash_at_capture": { "type": "string", "description": "sha256 of feature entry when evidence was captured. Mismatch → re-capture needed." },
        "code_hash_at_capture": { "type": ["string", "null"], "description": "Optional: sha256 of relevant source files at capture time." }
      }
    }
  }
}
