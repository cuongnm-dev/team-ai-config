#!/usr/bin/env bash
# ai-kit launcher — Node.js + Ink CLI
# Falls back to legacy bash CLI for commands not yet ported.

set -e
DIR="$(cd "$(dirname "$0")" && pwd)"

# Check Node.js >= 18
if ! command -v node >/dev/null 2>&1; then
  echo "✗ Node.js not found. Install Node 18+ and re-run." >&2
  echo "  macOS:  brew install node" >&2
  echo "  Linux:  https://nodejs.org/  (or use nvm)" >&2
  exit 1
fi

NODE_MAJOR=$(node -p 'process.versions.node.split(".")[0]')
if [ "$NODE_MAJOR" -lt 18 ]; then
  echo "✗ Node.js $NODE_MAJOR detected — ai-kit needs >= 18." >&2
  exit 1
fi

# Ensure node_modules present
REPO_ROOT="$(cd "$DIR/.." && pwd)"
if [ ! -d "$REPO_ROOT/node_modules" ]; then
  echo "▶ First run — installing Node deps (one-time)…"
  (cd "$REPO_ROOT" && npm install --omit=dev --silent) || {
    echo "✗ npm install failed; falling back to legacy CLI" >&2
    exec "$DIR/ai-kit.legacy" "$@"
  }
fi

exec node "$DIR/ai-kit.mjs" "$@"
