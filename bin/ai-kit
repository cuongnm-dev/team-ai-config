#!/usr/bin/env bash
# ai-kit launcher — Node.js + Ink CLI

set -e

# Resolve symlinks so SCRIPT_DIR = real repo bin/ (handles bootstrap symlink)
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  SDIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$SDIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"

# Canonical home — single source of truth for node_modules
AI_KIT_HOME="${AI_KIT_HOME:-$HOME/.ai-kit}"
REPO_DIR="$AI_KIT_HOME/team-ai-config"

# Node >= 18 check
if ! command -v node >/dev/null 2>&1; then
  echo "✗ Node.js not found. Install Node 18+:" >&2
  echo "  macOS:  brew install node" >&2
  echo "  Linux:  https://nodejs.org/" >&2
  exit 1
fi
NODE_MAJOR=$(node --version | cut -c2- | cut -d. -f1)
if [ "$NODE_MAJOR" -lt 18 ]; then
  echo "✗ Node.js $NODE_MAJOR detected — ai-kit needs >= 18." >&2
  exit 1
fi

# Install node_modules into AI_KIT_HOME if missing
if [ ! -d "$AI_KIT_HOME/node_modules" ]; then
  echo "▶ First run — installing Node deps (one-time)…"
  # Always copy latest package.json from repo to AI_KIT_HOME
  [ -f "$REPO_DIR/package.json" ] && cp "$REPO_DIR/package.json" "$AI_KIT_HOME/package.json"
  (cd "$AI_KIT_HOME" && npm install --omit=dev --silent) || {
    echo "✗ npm install failed" >&2
    echo "  Try manually: cd ~/.ai-kit && npm install --omit=dev" >&2
    exit 1
  }
fi

# Self-heal: sync bin/lib/ from repo if missing (post-modular-refactor)
if [ ! -d "$SCRIPT_DIR/lib" ] && [ -d "$REPO_DIR/bin/lib" ]; then
  cp -R "$REPO_DIR/bin/lib" "$SCRIPT_DIR/lib"
fi

exec node "$SCRIPT_DIR/ai-kit.mjs" "$@"
