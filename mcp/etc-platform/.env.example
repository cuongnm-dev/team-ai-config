# Copy this to `.env` and fill in your values.
# install.sh / install.ps1 auto-creates `.env` from this file on first run.

# Container image — replace `your-org` with your registry namespace.
# Example: ghcr.io/etc-corp/etc-platform:v0.4.0
ETC_PLATFORM_IMAGE=o0mrblack0o/etc-platform:v3.0.0

# Host port (default 8001). Change only if conflict with another service.
ETC_PLATFORM_PORT=8001

# Log verbosity: debug | info | warn | error
ETC_PLATFORM_LOG_LEVEL=info
