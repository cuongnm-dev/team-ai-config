# Force LF line endings for shell scripts (broken on Mac/Linux otherwise)
*.sh         text eol=lf
bin/ai-kit   text eol=lf

# Windows scripts: store as-is (BOM + CRLF preserved). PS 5.1 needs UTF-8 BOM to parse correctly;
# `-text` tells git not to normalize line endings or strip BOM.
*.ps1        -text
*.cmd        -text
*.bat        -text

# Markdown / config — let git handle (default)
*.md         text
*.json       text
*.yml        text
*.yaml       text
*.py         text eol=lf

# Binary
*.png        binary
*.jpg        binary
*.xlsx       binary
*.docx       binary
*.pdf        binary
