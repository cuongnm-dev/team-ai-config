  "description": "Root model for content-data.json — the contract between all pipeline phases.\n\nProducers:\n  - Phase 1 (tdoc-researcher): populates services[], overview\n  - Phase 2 (tdoc-test-runner): populates services[].features[].steps[].screenshot\n  - Phase 3 (tdoc-data-writer): populates test_cases, meta, project\n  - Manual: user edits directly\n\nConsumers:\n  - xlsx engine: reads project, meta, dev_unit, test_cases, test_sheets\n  - docx engine: reads project, meta, dev_unit, overview, services",
  "properties": {
    "project": {
      "$ref": "#/$defs/ProjectInfo"
    },
    "dev_unit": {
      "default": "Công ty CP Hệ thống Công nghệ ETC",
      "description": "Development company name",
      "title": "Dev Unit",
      "type": "string"
    },
    "meta": {
      "$ref": "#/$defs/Meta"
    },
    "overview": {
      "$ref": "#/$defs/Overview"
    },
    "test_sheets": {
      "$ref": "#/$defs/TestSheetConfig"
    },
    "services": {
      "items": {
        "$ref": "#/$defs/Service"
      },
      "title": "Services",
      "type": "array"
    },
    "test_cases": {
      "$ref": "#/$defs/TestCases"
    },
    "troubleshooting": {
      "description": "FAQ items for HDSD Section 2.4",
      "items": {
        "$ref": "#/$defs/TroubleshootingItem"
      },
      "title": "Troubleshooting",
      "type": "array"
    },
    "architecture": {
      "$ref": "#/$defs/Architecture",
      "description": "Architecture data for TKKT template"
    },
    "tkcs": {
      "$ref": "#/$defs/TkcsData",
      "description": "TKCS-specific data"
    },
    "tkct": {
      "$ref": "#/$defs/TkctData",
      "description": "TKCT (detailed design) data"
    }
  },
  "required": [
    "project",
    "meta"
  ],
  "title": "ContentData",
  "type": "object"
