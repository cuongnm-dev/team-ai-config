    "TestCaseRow": {
      "description": "A single test case row — the primary data unit.\n\nSupports two step formats:\n  1. Unified: steps[] with action + expected in each step (Playwright/Xray style)\n  2. Split:   steps[] (actions only) + expected[] (results only) — legacy/Excel-native\n\nThe engine normalizes to the split format for Excel column C/D mapping.",
      "properties": {
        "name": {
          "description": "Test case name → Excel col B",
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "steps": {
          "description": "Test steps with action (+ optional expected per step)",
          "items": {
            "anyOf": [
              {
                "$ref": "#/$defs/TestStep"
              },
              {
                "additionalProperties": true,
                "type": "object"
              }
            ]
          },
          "title": "Steps",
          "type": "array"
        },
        "expected": {
          "description": "Expected results (if not embedded in steps)",
          "items": {
            "anyOf": [
              {
                "$ref": "#/$defs/ExpectedResult"
              },
              {
                "additionalProperties": true,
                "type": "object"
              }
            ]
          },
          "title": "Expected",
          "type": "array"
        },
        "priority": {
          "$ref": "#/$defs/Priority",
          "default": "Normal",
          "description": "Severity: Rất cao|Cao|Trung bình|Thấp or Critical|Major|Normal|Minor"
        },
        "preconditions": {
          "default": "",
          "description": "Preconditions for this TC",
          "title": "Preconditions",
          "type": "string"
        },
        "checklog": {
          "default": "",
          "description": "Check log reference → Excel col E",
          "title": "Checklog",
          "type": "string"
        },
        "redirect": {
          "default": "",
          "description": "Redirect/navigation target → Excel col F",
          "title": "Redirect",
          "type": "string"
        },
        "notes": {
          "default": "",
          "description": "Additional notes → Excel col M",
          "title": "Notes",
          "type": "string"
        },
        "feature_id": {
          "default": "",
          "description": "Links to services[].features[].id (e.g. F-001)",
          "title": "Feature Id",
          "type": "string"
        },
        "tc_id": {
          "default": "",
          "description": "Unique test case ID (auto-generated if empty)",
          "title": "Tc Id",
          "type": "string"
        },
        "labels": {
          "description": "Tags/labels: ['smoke', 'regression', 'ui']",
          "items": {
            "type": "string"
          },
          "title": "Labels",
          "type": "array"
        }
      },
